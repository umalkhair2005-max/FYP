# Copy this file to ".env" in the SAME folder as this example (project root),
# or to "backend/.env". Fill in your key from https://aistudio.google.com/apikey
#
GOOGLE_API_KEY=

# Optional aliases (same value as GOOGLE_API_KEY if you prefer):
# GEMINI_API_KEY=

# Optional other providers (see Settings in the app):
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Flask session secret (recommended for production):
# FLASK_SECRET_KEY=
